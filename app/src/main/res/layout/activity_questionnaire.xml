<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="#FF1E3A5F">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true"
        android:layout_marginTop="20dp"
        android:layout_marginStart="5dp"
        android:background="@android:color/transparent"
        android:src="@drawable/baseline_arrow_back_24"
        android:contentDescription="Back"
        app:tint="@android:color/black" />

    <ImageView
        android:id="@+id/imgProfile"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="5dp"
        android:clickable="true"
        android:focusable="true"
        android:scaleType="centerCrop"
        android:src="@drawable/baseline_face_24" />


    <LinearLayout
        android:id="@+id/cardContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_margin="24dp"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/bg_question_card">

        <TextView
            android:id="@+id/txtModeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Erasmus Questionnaire"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="18sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <ProgressBar
                android:id="@+id/progressQuestions"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="0dp"
                android:layout_height="8dp"
                android:layout_weight="1"
                android:progress="1"
                android:max="5"
                android:progressDrawable="@drawable/progress_questions_drawable" />

            <TextView
                android:id="@+id/txtProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1 / 5"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutSteps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="12dp">

            <ImageView
                android:id="@+id/step1"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_step_inactive"
                android:layout_margin="4dp" />

            <ImageView
                android:id="@+id/step2"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_step_inactive"
                android:layout_margin="4dp" />

            <ImageView
                android:id="@+id/step3"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_step_inactive"
                android:layout_margin="4dp" />

            <ImageView
                android:id="@+id/step4"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_step_inactive"
                android:layout_margin="4dp" />

            <ImageView
                android:id="@+id/step5"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:src="@drawable/ic_step_inactive"
                android:layout_margin="4dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txtQuestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Question text here"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp" />

        <EditText
            android:id="@+id/edtAnswer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Type your answer..."
            android:layout_marginTop="12dp"
            android:padding="12dp"
            android:background="@drawable/bg_answer_input"
            android:textColor="#FFFFFF"
            android:textColorHint="#80FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="20dp">

            <Button
                android:id="@+id/btnPrev"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Back"
                android:textAllCaps="false"
                android:background="@drawable/btn_secondary"
                android:textColor="#FFFFFF" />

            <Button
                android:id="@+id/btnNext"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Next"
                android:textAllCaps="false"
                android:layout_marginStart="12dp"
                android:background="@drawable/btn_primary"
                android:textColor="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
