<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1E3A5F"
    android:padding="20dp">

    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@android:color/transparent"
                android:src="@drawable/baseline_arrow_back_24"
                android:contentDescription="Back"
                app:tint="@android:color/white" />

            <TextView
                android:id="@+id/txtAccountTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="My account"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:gravity="center" />

            <View
                android:layout_width="40dp"
                android:layout_height="40dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardUserBasic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_account_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imgProfilePhoto"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/baseline_face_24"
                    android:background="@drawable/bg_profile_circle"
                    android:padding="16dp"
                    android:scaleType="centerCrop"
                    android:clickable="true"
                    android:focusable="true"
                    android:contentDescription="Profile photo"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtFullName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Full Name"
                        android:textColor="@android:color/white"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/txtEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="email@example.com"
                        android:textColor="#CCFFFFFF"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/txtPhone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+30 69..."
                        android:textColor="#CCFFFFFF"
                        android:textSize="14sp" />
                </LinearLayout>
            </LinearLayout>


        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardUserInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_account_card">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Academic profile"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/txtUniversity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="University: -"
                android:textColor="#DDFFFFFF"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtAcademicLevel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Level: -"
                android:textColor="#DDFFFFFF"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtField"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Field: -"
                android:textColor="#DDFFFFFF"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtLanguages"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Languages: -"
                android:textColor="#DDFFFFFF"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtGpa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPA: -"
                android:textColor="#DDFFFFFF"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtBudget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Budget per year: -"
                android:textColor="#DDFFFFFF"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtYearOfStudies"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Year of studies: -"
                android:textColor="#DDFFFFFF"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/txtAdvisorType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Advisor type: -"
                android:textColor="#DDFFFFFF"
                android:layout_marginBottom="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/cardActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_account_card">

            <Button
                android:id="@+id/btnEditProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Edit profile"
                android:textAllCaps="false"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnEditAcademic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Edit academic info"
                android:textAllCaps="false"
                android:layout_marginBottom="12dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
